{
  "name": "blessluxe",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "type-check": "turbo type-check",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@blessluxe/eslint-config": "workspace:*",
    "@blessluxe/prettier-config": "workspace:*",
    "prettier": "^3.2.5",
    "turbo": "^2.1.3"
  },
  "packageManager": "pnpm@9.12.3",
  "prettier": "@blessluxe/prettier-config",
  "pnpm": {
    "overrides": {
      "zod": "3.25.76"
    }
  }
}
