# Shop Backend (port 9001 to avoid conflict with Medusa on 9000)
DATABASE_URL=postgres://blessluxe:blessluxe@localhost:5432/blessluxe
PORT=9001
STORE_CORS=http://localhost:3000
ADMIN_CORS=http://localhost:3001
PUBLISHABLE_API_KEY=pk_blessluxe_dev
JWT_SECRET=blessluxe-shop-secret-change-me
# Image upload directory (local filesystem)
UPLOAD_DIR=./uploads

# Paynow web integration (Zimbabwean payment gateway).
# Get these from Paynow merchant dashboard → Integration. The Integration Key
# is a hashing secret and MUST be kept server-side only. Never expose it to
# the browser or commit it.
PAYNOW_INTEGRATION_ID=
PAYNOW_INTEGRATION_KEY=
# Where Paynow POSTs the status callback (must be publicly reachable HTTPS).
PAYNOW_RESULT_URL=http://localhost:9001/store/payments/paynow/ipn
# Where Paynow redirects the customer after they finish on its hosted page.
PAYNOW_RETURN_URL=http://localhost:9001/store/payments/paynow/return
# While the Paynow integration is "in testing", Paynow rejects any authemail
# that isn't the merchant's registered email. Set this to the merchant email
# during local/dev so all checkouts pass. Leave empty in production.
PAYNOW_AUTH_EMAIL_OVERRIDE=
