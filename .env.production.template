# ╔══════════════════════════════════════════════════════════════════════╗
# ║  BLESSLUXE — Production Environment (DigitalOcean Droplet)          ║
# ║                                                                      ║
# ║  Usage:                                                              ║
# ║    cp .env.production.template .env                                  ║
# ║    nano .env   # fill in REQUIRED + any OPTIONAL services you want   ║
# ║    docker compose up -d --build                                      ║
# ║                                                                      ║
# ║  Legend: 🔴 REQUIRED · 🟡 RECOMMENDED · ⚪ OPTIONAL                  ║
# ║  Replace blessluxe.com everywhere with your real domain.             ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ╭─────────────────────────────────────────────────────────────────────╮
# │ 🔴 DATABASE  (required — auto-set by setup.sh if you let it)        │
# ╰─────────────────────────────────────────────────────────────────────╯
POSTGRES_USER=blessluxe
POSTGRES_PASSWORD=CHANGE_ME_RANDOM_HEX
POSTGRES_DB=blessluxe


# ╭─────────────────────────────────────────────────────────────────────╮
# │ 🔴 BACKEND SECRETS  (required — generate fresh with openssl)        │
# │   openssl rand -hex 32                                              │
# ╰─────────────────────────────────────────────────────────────────────╯
JWT_SECRET=CHANGE_ME_RANDOM_HEX_64_CHARS
NEXTAUTH_SECRET=CHANGE_ME_RANDOM_HEX_64_CHARS
SHOP_PUBLISHABLE_API_KEY=pk_blessluxe_prod


# ╭─────────────────────────────────────────────────────────────────────╮
# │ 🔴 PUBLIC URLS  (required — must match your DNS / Caddy config)     │
# ╰─────────────────────────────────────────────────────────────────────╯
# Customer-facing storefront domain
NEXT_PUBLIC_SITE_URL=https://blessluxe.com
NEXT_PUBLIC_STORE_URL=https://blessluxe.com
DEFAULT_SITE_URL=https://blessluxe.com
EMAIL_DEFAULT_SITE_URL=https://blessluxe.com

# Where the BROWSER reaches the shop API
NEXT_PUBLIC_COMMERCE_BACKEND=https://api.blessluxe.com
# Legacy alias still read by some files; keep it identical to the above
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://api.blessluxe.com

# Where the ADMIN browser reaches the shop API
NEXT_PUBLIC_SHOP_BACKEND=https://api.blessluxe.com

# Where the storefront's SERVER (Node) reaches shop — internal DNS, no HTTPS
SHOP_BACKEND_INTERNAL_URL=http://shop:9001

# Allowed origins for the shop API's CORS
STORE_CORS=https://blessluxe.com,https://www.blessluxe.com
ADMIN_CORS=https://admin.blessluxe.com

# NextAuth (customer OAuth) — must equal the storefront's public URL
NEXTAUTH_URL=https://blessluxe.com


# ╭─────────────────────────────────────────────────────────────────────╮
# │ 🟡 STRIPE PAYMENTS  (recommended — needed to actually take orders)  │
# │   Get keys at https://dashboard.stripe.com/apikeys                  │
# ╰─────────────────────────────────────────────────────────────────────╯
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Set "1" to bypass Stripe entirely (uses a test simulator). Use this until
# your real keys are ready so the checkout flow is exercisable.
NEXT_PUBLIC_PAYMENT_GATEWAY_SIMULATE=0


# ╭─────────────────────────────────────────────────────────────────────╮
# │ 🟡 GOOGLE OAUTH  (recommended — one-click customer sign-in)          │
# │   Console → https://console.cloud.google.com/apis/credentials       │
# │   Authorised redirect URI: https://blessluxe.com/api/auth/callback/google │
# ╰─────────────────────────────────────────────────────────────────────╯
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# ╭─────────────────────────────────────────────────────────────────────╮
# │ 🟡 GOOGLE GEMINI AI  (recommended — powers the in-store AI agent)   │
# │   Get a free key: https://aistudio.google.com/apikey                │
# ╰─────────────────────────────────────────────────────────────────────╯
GOOGLE_AI_API_KEY=
# Same key exposed to the browser for voice/chat widget
NEXT_PUBLIC_GOOGLE_AI_API_KEY=
# Optional model overrides — defaults are sensible
# GEMINI_MODEL=gemini-2.5-flash
# GOOGLE_NANO_BANANA_MODEL=gemini-3.1-flash-image-preview


# ╭─────────────────────────────────────────────────────────────────────╮
# │ 🟡 TRANSACTIONAL EMAIL  (recommended — order confirmations, etc.)   │
# │   Pick ONE: SendGrid OR SMTP. Leave the other section blank.        │
# ╰─────────────────────────────────────────────────────────────────────╯

# ── Option A: SendGrid (easiest for production) ──
# Get an API key: https://app.sendgrid.com/settings/api_keys
STOREFRONT_EMAIL_PROVIDER=
SENDGRID_API_KEY=
SENDGRID_FROM=BLESSLUXE <info@blessluxe.com>

# ── Option B: SMTP (Gmail, Zoho, Mailgun, etc.) ──
# Gmail needs an App Password, not your normal password.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=BLESSLUXE <info@blessluxe.com>
SMTP_REQUIRE_TLS=true
SMTP_TLS_REJECT_UNAUTHORIZED=true

# Where customer replies go (any email)
REPLY_TO_EMAIL=hello@blessluxe.com
SMTP_REPLY_TO=hello@blessluxe.com


# ╭─────────────────────────────────────────────────────────────────────╮
# │ ⚪ ADMIN PORTAL GATE  (optional — extra layer on /admin)             │
# │   Either a shared key OR a comma-separated email allow-list.        │
# ╰─────────────────────────────────────────────────────────────────────╯
ADMIN_DASHBOARD_KEY=
ADMIN_EMAILS=


# ╭─────────────────────────────────────────────────────────────────────╮
# │ ⚪ SUPABASE STORAGE  (optional — affiliate media uploads, S3-like)  │
# │   Project URL: Supabase dashboard → Settings → API                  │
# ╰─────────────────────────────────────────────────────────────────────╯
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=affiliate-media


# ╭─────────────────────────────────────────────────────────────────────╮
# │ ⚪ ELEVENLABS VOICE  (optional — TTS for the AI agent)               │
# │   Get key at https://elevenlabs.io/api                              │
# ╰─────────────────────────────────────────────────────────────────────╯
ELEVENLABS_VOICE_ID=


# ╭─────────────────────────────────────────────────────────────────────╮
# │ ⚪ AI AGENT FEATURE FLAGS  (optional — defaults are fine)            │
# ╰─────────────────────────────────────────────────────────────────────╯
NEXT_PUBLIC_AI_AGENT_PROVIDER=gemini
NEXT_PUBLIC_AI_AGENT_MODEL=gemini-2.5-flash
NEXT_PUBLIC_AI_AGENT_MAX_TOOL_CALLS=6
NEXT_PUBLIC_AI_MEMORY_ENABLED=true
NEXT_PUBLIC_AI_VOICE_ENABLED=true
NEXT_PUBLIC_VOICE_STT_PROVIDER=browser
NEXT_PUBLIC_VOICE_TTS_PROVIDER=browser


# ╭─────────────────────────────────────────────────────────────────────╮
# │ ⚪ MISC                                                              │
# ╰─────────────────────────────────────────────────────────────────────╯
# Where the shop backend writes uploaded files inside its container.
# Maps to the shop_uploads volume — don't change unless you know why.
UPLOAD_DIR=/app/backend/shop/uploads
